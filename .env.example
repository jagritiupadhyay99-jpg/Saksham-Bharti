# ============================================================
# Saksham Bharti Foundation — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your real values.
# DO NOT put real passwords in this file!
# ============================================================

# --- Database ---
DB_HOST=localhost
DB_NAME=saksham_db
DB_USER=root
DB_PASS=

# --- SMTP Email ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM_EMAIL=no-reply@sakshambharti.org
MAIL_FROM_NAME=Saksham Bharti Foundation

# --- App Settings ---
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/saksham-bharti
